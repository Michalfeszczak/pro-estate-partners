# ============================================================
# ENVIRONMENT CONFIGURATION - PRO ESTATE PARTNERS
# ============================================================
#
# Instrukcja:
# 1. Skopiuj ten plik: cp .env.example .env
# 2. Wypełnij wartości dla Twojego środowiska
# 3. Nigdy nie commituj .env do Git
# 4. .env jest ignorowany w .gitignore
#
# ============================================================

# ============================================================
# ENVIRONMENT (production, staging, development)
# ============================================================
ENVIRONMENT=development

# ============================================================
# DOMAIN CONFIGURATION
# ============================================================
DOMAIN=https://proestatepartners.com
DOMAIN_LOCAL=http://localhost:8001

# ============================================================
# GOOGLE SERVICES
# ============================================================
# Google Analytics 4
# Pobierz z: https://analytics.google.com
# ID wygląda jak: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=

# Google Tag Manager
# Pobierz z: https://tagmanager.google.com
# ID wygląda jak: GTM-XXXXXXXX
GOOGLE_TAG_MANAGER_ID=

# Google Search Console
# Verification code z: https://search.google.com/search-console
GOOGLE_SEARCH_CONSOLE_VERIFY=

# ============================================================
# FACEBOOK / META SERVICES
# ============================================================
# Meta Pixel ID (Facebook Pixel)
# Pobierz z: https://business.facebook.com/
# ID to 16-cyfrowa liczba
META_PIXEL_ID=

# Facebook App ID (dla Facebook SDK)
FACEBOOK_APP_ID=

# Facebook Page ID (dla integracji)
FACEBOOK_PAGE_ID=

# ============================================================
# SESSION RECORDING & ANALYTICS
# ============================================================
# Hotjar Site ID
# Pobierz z: https://www.hotjar.com
HOTJAR_ID=

# Microsoft Clarity Project ID
# Pobierz z: https://clarity.microsoft.com
CLARITY_ID=

# ============================================================
# SOCIAL MEDIA & ADVERTISING
# ============================================================
# LinkedIn Insight Partner ID
# Pobierz z: https://business.linkedin.com/
LINKEDIN_PARTNER_ID=

# TikTok Pixel ID
# Pobierz z: https://ads.tiktok.com/
TIKTOK_PIXEL_ID=

# ============================================================
# CONTACT & BUSINESS INFO
# ============================================================
# Numer telefonu (format: +48XXXXXXXXX)
PHONE_NUMBER=+48602218958

# Email (jeśli będzie formularz)
EMAIL=info@proestatepartners.com

# Adres (jeśli będzie Google Maps)
ADDRESS=Szczecin, Polska

# ============================================================
# DEBUG & DEVELOPMENT
# ============================================================
# Debug mode - wyświetla informacje w konsoli
DEBUG_MODE=true

# Verbose logging - szczegółowe logi
VERBOSE_LOGGING=false

# ============================================================
# FEATURE FLAGS
# ============================================================
# Włączenie/wyłączenie funkcji (true/false)

# Śledzenie kliknięć na telefon
TRACK_PHONE_CLICKS=true

# Śledzenie wysyłania formularzy (jeśli będą)
TRACK_FORM_SUBMISSIONS=false

# Śledzenie scroll depth
TRACK_SCROLL_DEPTH=false

# Cookies consent banner
SHOW_COOKIES_BANNER=true

# ============================================================
# PERFORMANCE
# ============================================================
# Lazy loading dla zdjęć
LAZY_LOAD_IMAGES=true

# Prefetch DNS dla external domains
DNS_PREFETCH=true

# Cache strategy (network-first, cache-first, stale-while-revalidate)
CACHE_STRATEGY=network-first

# ============================================================
# SECURITY
# ============================================================
# Content Security Policy
CSP_ENABLED=true

# HTTPS only
HTTPS_ONLY=true

# X-Frame-Options (clickjacking protection)
X_FRAME_OPTIONS=SAMEORIGIN

# ============================================================
# THIRD PARTY SERVICES
# ============================================================
# SendGrid (email service) - jeśli będzie używany
SENDGRID_API_KEY=

# Stripe (payments) - jeśli będą płatności
STRIPE_PUBLIC_KEY=

# Zapier webhooks
ZAPIER_WEBHOOK_URL=

# ============================================================
# WORDPRESS (jeśli będzie migracja)
# ============================================================
# WordPress API endpoint
WP_API_URL=https://proestatepartners.com/wp-json

# WordPress API key
WP_API_KEY=

# ============================================================
# MAINTENANCE MODE
# ============================================================
# Tryb maintenance
MAINTENANCE_MODE=false

# Komunikat maintenance
MAINTENANCE_MESSAGE=Strona jest w trakcie konserwacji. Proszę powrócić później.

# ============================================================
# LOGGING & MONITORING
# ============================================================
# Sentry (error tracking)
SENTRY_DSN=

# LogRocket (session replay)
LOGROCKET_ID=

# ============================================================
# NOTES
# ============================================================
# Lokalnie (development):
# - Możesz zostawić puste wszystkie API keys
# - Aplikacja będzie działać bez śledzenia
# - Debug mode = true (będą logi w konsoli)
#
# Na produkcji:
# - Wpisz wszystkie API keys
# - ENVIRONMENT = production
# - DEBUG_MODE = false
# - HTTPS_ONLY = true
#