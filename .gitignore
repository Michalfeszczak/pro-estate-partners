# ============================================================
# SYSTEM FILES
# ============================================================
Thumbs.db                   # Windows
.DS_Store                   # macOS
ehthumbs.db

# ============================================================
# BACKUP FILES
# ============================================================
*.bak
*.backup
*~
*.orig
*.swp
*.swo

# ============================================================
# COMPRESSED FILES (opcjonalne)
# ============================================================
# Jeśli robisz backupy, możesz je ignorować
*.zip
*.tar
*.tar.gz
*.rar

