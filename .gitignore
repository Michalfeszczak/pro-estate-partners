# ============================================================
# .GITIGNORE - PRO ESTATE PARTNERS
# ============================================================
# Pliki które NIE POWINNY być commitowane do Git
#
# Nigdy nie commituj:
# - Zmiennych środowiskowych (.env)
# - Kluczy API i tokenów
# - Haseł
# - Danych prywatnych
# - Node modules (jeśli będzie)
# - Build artifacts
# ============================================================

# ============================================================
# ENVIRONMENT & CONFIGURATION
# ============================================================
.env                          # Zmienne środowiskowe (NIGDY!)
.env.local                    # Lokalne zmienne
.env.*.local                  # Stage-specific env files
.env.development.local        # Development-only env
.env.test.local               # Test-only env
.env.production.local         # Production-only env

# ============================================================
# SECRETS & CREDENTIALS
# ============================================================
*.key                         # Private keys
*.pem                         # Certificate files
*.p12                         # PKCS12 files
.aws/                         # AWS credentials
.gcloud/                      # Google Cloud credentials
credentials.json              # Google credentials
firebase-key.json             # Firebase config
.ssh/                         # SSH keys

# ============================================================
# IDE & EDITOR FILES
# ============================================================
# VS Code
.vscode/
.vscode/settings.json
.vscode/extensions.json

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr
.DS_Store

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*~
.*.swp
.*.swo

# Emacs
*~
\#*\#

# TextMate
*.tmproj
*.tmproject

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Duplicate local image export without extension
images/mapa-obszar

# ============================================================
# NODE & DEPENDENCIES
# ============================================================
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
package-lock.json          # Optional (zależy od preferencji)
yarn.lock                   # Optional

