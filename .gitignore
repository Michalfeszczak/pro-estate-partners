/drafts/
/temp-files/

# Logi z serwera
/server-logs/
server.log

# Dane testowe (jeśli będą)
/test-data/
test-database.db

# Zrzuty ekranów / mockupy
/mockups/
/screenshots/

# Notatki zespołu
team-notes.txt
INTERNAL.md

# ============================================================
# NOTES FOR TEAM
# ============================================================
# Commits - zawsze uruchamiaj:
# 1. git status     - sprawdzenie co się zmienia
# 2. git diff       - szczegółowy przegląd zmian
# 3. Upewnij się że .env nie jest staged (git status)
#
# Jeśli niechcący commitałeś .env:
# git rm --cached .env
# git commit --amend -m "Remove .env from history"
